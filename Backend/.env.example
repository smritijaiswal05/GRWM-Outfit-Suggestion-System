# Backend Environment Variables
# Copy this to .env and update with your actual values

# MongoDB Connection String
MONGO_CONNECTION_STRING=mongodb+srv://admin:admin123@cluster0.fzt0yhs.mongodb.net/?appName=Cluster0

# JWT Configuration
JWT_SECRET=your_very_long_and_random_secret_key_with_at_least_32_characters_here_12345678
JWT_EXPIRATION_DAYS=7

# Allowed Origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8001

# Server Configuration
AUTH_SERVER_PORT=8001
AI_SERVER_PORT=8000
BASE_URL=http://localhost:8001
AI_BACKEND_URL=http://localhost:8000
